{
  "buildCommand": "node build-esbuild.mjs",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/catch/:id",
      "destination": "https://fishing-go-backend.onrender.com/og/catch/:id",
      "permanent": false,
      "missing": [{ "type": "query", "key": "ref" }]
    },
    {
      "source": "/post/:id",
      "destination": "https://fishing-go-backend.onrender.com/og/post/:id",
      "permanent": false,
      "missing": [{ "type": "query", "key": "ref" }]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
