{
  "name": "fishing-go",
  "private": true,
  "version": "1.0.37",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:esbuild",
    "build:esbuild": "node build-esbuild.mjs",
    "preview": "vite preview",
    "cap:sync": "npx cap sync android",
    "cap:android": "npx cap open android",
    "apk": "npm run build:esbuild && npx cap sync android",
    "version:apply": "node update-version.cjs",
    "release:patch": "npm version patch --no-git-tag-version && node update-version.cjs --push",
    "release:minor": "npm version minor --no-git-tag-version && node update-version.cjs --push",
    "release:major": "npm version major --no-git-tag-version && node update-version.cjs --push"
  },
