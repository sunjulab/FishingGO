# ==========================================
# 🎣 낚시GO Frontend Environment Variables
# ==========================================

# 1. 백엔드(서버) 접속 주소
# 로컬 개발 시에는 http://localhost:5000 을 사용합니다.
# Vercel/Render 등에 배포 후에는 실제 서버 주소로 변경하세요.
VITE_API_URL=http://localhost:5000

# 2. 카카오 앱 키 (카카오맵 + 공유 기능)
# https://developers.kakao.com 에서 발급
VITE_KAKAO_APP_KEY=your_kakao_js_key_here

# 3. Google AdSense (광고 수익)
# https://www.google.com/adsense 에서 발급
# ⚠️ 미설정 시 구글 공식 테스트 키가 자동 적용됩니다 (수익 없음)
VITE_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT_BANNER=XXXXXXXXXX
VITE_ADSENSE_SLOT_NATIVE=XXXXXXXXXX

# 4. 쿠팡 파트너스 (쇼핑 탭 수익화)
# https://partners.coupang.com 에서 파트너스 ID 확인
# ⚠️ 미설정 시 기본 ID가 사용됩니다
VITE_COUPANG_PARTNERS_ID=your_partners_id_here   # ✅ 12TH-C3: 혼동 방지 — AF0000000은 실제 ID 포맷으로 오인 가능

# 5. 포트원 결제 (구독 결제)
# https://portone.io 에서 가맹점 식별코드 발급
# ⚠️ 미설정 시 테스트 모드로 동작합니다 (실결제 안됨)
VITE_PORTONE_MERCHANT_ID=imp00000000
VITE_TOSS_PG_CODE=tosspayments
VITE_NAVER_PG_CODE=naverpay
