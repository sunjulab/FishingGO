# ==========================================
# 🎣 낚시GO Frontend Environment Variables
# ==========================================

# 1. 백엔드(서버) 접속 주소 
# 로컬 개발 시에는 http://localhost:5000 을 사용합니다.
# Vercel/Render 등에 배포 후에는 실제 서버 주소로 변경하세요. (예: https://fishinggo-api.onrender.com)
VITE_API_URL=http://localhost:5000

# 2. 클라이언트 전용 카카오맵 또는 공공데이터 키 (선택 사항)
# VITE_KAKAO_MAP_KEY=your_kakao_js_key_here
