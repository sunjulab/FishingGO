# ────────────────────────────────────────────────────────────────
# 낚시GO 서버 환경변수 템플릿
# 이 파일을 복사하여 .env 파일로 저장하고 값을 채워주세요.
# cp .env.example .env
# ────────────────────────────────────────────────────────────────

# ── 필수 보안 설정 (반드시 변경!) ────────────────────────────────
# JWT 토큰 서명 비밀키 (아래 명령으로 랜덤 생성):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=여기에_랜덤_64자_이상의_비밀키를_입력하세요

# ── MongoDB 연결 ──────────────────────────────────────────────────
# MongoDB Atlas 연결 문자열 (특수문자는 URL 인코딩 필요)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fishinggo?retryWrites=true&w=majority

# ── 서버 설정 ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Render 배포 설정 ─────────────────────────────────────────────
# Render 외부 URL - 슬립 방지 keep-alive에 사용됨
# 예: https://fishinggo-api.onrender.com
RENDER_EXTERNAL_URL=

# ── CORS 허용 도메인 ──────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app

# ── SMS 인증 (CoolSMS) ───────────────────────────────────────────
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
SMS_SENDER=01000000000

# ── 날씨/해양 API ─────────────────────────────────────────────────
WEATHER_API_KEY=
KHOA_API_KEY=

# ────────────────────────────────────────────────────────────────
# 주의: .env 파일은 절대 Git에 커밋하지 마세요!
# ────────────────────────────────────────────────────────────────
