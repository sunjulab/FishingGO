# ==========================================
# 🎣 낚시GO Backend (Server) Environment Variables
# ==========================================

# 1. MongoDB 연결 주소
# 로컬 테스트 시에는 mongodb://127.0.0.1:27017/fishinggo 를 사용하지만,
# 상용화 배포 시에는 MongoDB Atlas 주소를 여기에 반드시 넣어야 합니다!
# 예시: mongodb+srv://admin:비밀번호@cluster0.abcde.mongodb.net/fishinggo?retryWrites=true&w=majority
MONGO_URI=

# 2. 공공데이터포털(KHOA/KMA) 실시간 해양 API 키
# 정부 API 신청 후 발급받은 실제 인증 키를 넣으세요.
KHOA_KEY=

# 3. JWT 비밀키 (유저 인증용)
# 아무 숫자와 영문자 조합 64자리 이상을 자유롭게 쓰면 됩니다.
JWT_SECRET=super_secret_fishinggo_auth_key_12345!

# 4. 서버 포트 번호
PORT=5000
