# ────────────────────────────────────────────────────────────────
# 낚시GO 서버 환경변수 템플릿
# 이 파일을 복사하여 .env 파일로 저장하고 값을 채워주세요.
# cp .env.example .env
# ────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════
# ⚠️ 프로덕션 배포 (Render) 보안 지침
# ════════════════════════════════════════════════════════════════
# .env 파일은 로컬 개발 전용입니다.
# Render 배포 시에는 아래 방법을 사용하세요:
#
# 1. Render 대시보드 접속: https://dashboard.render.com
# 2. 해당 서비스 → [Environment] 탭 클릭
# 3. [Add Environment Variable] 버튼으로 아래 키/값 직접 입력
# 4. 프로덕션 서버에 .env 파일을 업로드하거나 git에 커밋 금지!
# ════════════════════════════════════════════════════════════════

# ── 필수 보안 설정 (반드시 변경!) ────────────────────────────────
# JWT 토큰 서명 비밀키 (아래 명령으로 랜덤 생성):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=여기에_랜덤_64자_이상의_비밀키를_입력하세요

# ── MongoDB 연결 ──────────────────────────────────────────────────
# MongoDB Atlas 연결 문자열 (특수문자는 URL 인코딩 필요)
# ✅ BUG-40 수정: 서버가 실제로 읽는 키는 MONGO_URI 입니다 (MONGODB_URI 아님!)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fishinggo?retryWrites=true&w=majority
# NEW-A5: MONGO_PASS 용도 설명
# MONGO_URI에 비밀번호를 직접 포함하기 어려운 경우(특수문자 등) 사용.
# 서버는 buildMongoUri()에서 MONGO_URI가 없을 때
# mongodb+srv://sunjulab:<MONGO_PASS>@cluster0.xxxxx.mongodb.net/fishinggo 형식으로 조합합니다.
# MONGO_URI가 있으면 MONGO_PASS는 무시됩니다.
MONGO_PASS=

# ── 서버 설정 ────────────────────────────────────────────────────
PORT=5000
# 로컬 개발: development / Render 배포: production
NODE_ENV=development

# ── Render 배포 설정 ─────────────────────────────────────────────
# Render 외부 URL - 슬립 방지 keep-alive에 사용됨
# 예: https://fishinggo-api.onrender.com
RENDER_EXTERNAL_URL=

# ── CORS 허용 도메인 ──────────────────────────────────────────────
# ✅ 10TH-A3 + 12TH-C4: FRONTEND_URL → ALLOWED_ORIGIN 통일 (server/index.js와 render.yaml 일치)
ALLOWED_ORIGIN=https://your-frontend.vercel.app

# ── 포트원 결제 설정 ──────────────────────────────────────────────
# 포트원 콘솔(https://admin.portone.io) → 결제연동 → 웹훅
# 웹훅 URL 등록: https://[서버도메인]/api/payment/webhook
PORTONE_API_KEY=
PORTONE_API_SECRET=
# 웹훅 시크릿키: 포트원 콘솔 → 결제연동 → 웹훅 → 시크릿키 확인
PORTONE_WEBHOOK_SECRET=

# ── SMS 인증 (CoolSMS) ───────────────────────────────────────────
SMS_API_KEY=
SMS_API_SECRET=
# 반드시 CoolSMS에 사전 등록된 발신번호로 변경!
SMS_SENDER=01000000000

# ── 날씨/해양 API ─────────────────────────────────────────────────
# ✅ SEC-01 조치: 키 없으면 fallback 기상 데이터 자동 사용 (서비스 중단 없음)
KHOA_KEY=
KMA_KEY=
KHOA_CCTV_KEY=
# ✅ SEC-02 조치: 키 없으면 yt-search fallback 자동 사용 (서비스 중단 없음)
YOUTUBE_API_KEY=

# ── 클라이언트(Vite) 환경변수 ─────────────────────────────────────
# Vite 빌드 시 포함됨. VITE_ 접두어 필수.
# ✅ SEC-04: 카카오 JS SDK 공유 기능용 앱 키 (카카오 개발자 콘솔 → 내 애플리케이션)
VITE_KAKAO_APP_KEY=
# ✅ BUG-59: 쿠팡 파트너스 ID (Shop.jsx, 클라이언트 URL 추적용)
VITE_COUPANG_PARTNERS_ID=
# ✅ SEC-07: KHOA 해양 API 키 (조석예보/수온/낚시지수) — marineApi.js에서 사용
# https://www.khoa.go.kr/api → 오픈 API → 발급 신청 (무료)
VITE_KHOA_API_KEY=
# 서버 API 주소 (로컬: http://localhost:5000 / 배포: https://your-api.onrender.com)
VITE_API_URL=http://localhost:5000

# ── Cloudinary 이미지 CDN (선택) ─────────────────────────────────
# 설정 시 프로필 사진을 Cloudinary CDN으로 자동 업로드
# https://cloudinary.com → Settings → API Keys에서 확인
# 형식: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# ════════════════════════════════════════════════════════════════
# 🔴 보안 경고
# ════════════════════════════════════════════════════════════════
# 1. .env 파일은 절대 Git에 커밋하지 마세요! (.gitignore에 포함됨)
# 2. 프로덕션 키를 소스코드에 하드코딩하지 마세요!
# 3. 키 노출 의심 시 즉시 각 서비스에서 키를 재발급하세요:
#    - Google Cloud Console: https://console.cloud.google.com (YouTube API)
#    - KHOA 해양 API: https://www.khoa.go.kr/oceangrid/koofs/main.do
#    - CoolSMS: https://console.coolsms.co.kr
#    - PortOne: https://admin.portone.io
# ════════════════════════════════════════════════════════════════
